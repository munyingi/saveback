# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real keys, and never paste secret
# keys into chat. NEXT_PUBLIC_* values are safe to ship to the browser.

# --- Supabase (public, safe in the browser) ---
# Project Settings → Data API / API Keys.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
# New-style publishable key (sb_publishable_…). Acts as the anon role, RLS-gated.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# Legacy projects can use the anon key instead (clients fall back to this name):
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Public origin, used to build /u/[handle] invite links and QR codes.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Server-only secrets (NEVER prefix with NEXT_PUBLIC, NEVER paste in chat) ---
# Secret key (sb_secret_…) — bypasses RLS. Used ONLY by moderation/admin code.
# Legacy alias also accepted: SUPABASE_SERVICE_ROLE_KEY
SUPABASE_SECRET_KEY=sb_secret_xxx

# Postgres connection string — for applying/verifying the schema via psql.
# Project Settings → Database → Connection string → URI (includes the password).
SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.YOUR-PROJECT-REF.supabase.co:5432/postgres

# Salt used to hash a banned person's phone/email before storing in
# banned_identifiers. Generate: openssl rand -hex 32
BAN_HASH_SALT=replace-with-a-long-random-secret
